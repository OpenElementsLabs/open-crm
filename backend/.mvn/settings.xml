<?xml version="1.0" encoding="UTF-8"?>
<!--
    Project-local Maven settings used by Docker image builds (spec 107).
    The 'github' server matches the repository declared in pom.xml and
    supplies the credentials Maven needs to pull
    com.open-elements:spring-services:1.0.0-SNAPSHOT from GitHub Packages.

    Both fields read from environment variables so this file can be
    committed. The Dockerfile passes them via ARG to ENV; CI forwards
    GITHUB_ACTOR and the workflow's GITHUB_TOKEN.

    Local builds that don't need the snapshot can leave the vars unset.
    Maven only contacts the github server when an artifact actually
    requires it.
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">
    <servers>
        <server>
            <id>github</id>
            <username>${env.GITHUB_ACTOR}</username>
            <password>${env.GITHUB_TOKEN}</password>
        </server>
    </servers>
</settings>
